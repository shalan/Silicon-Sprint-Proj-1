{
    "DESIGN_NAME": "attoio_wrap",

    "//": "Project-level hardening override. Targets attoio_wrap (rtl/attoio_wrap.v)",
    "//-": "which hides the unused hp0/hp1/hp2 host-peripheral bundles. The macro",
    "//--": "ends up with a clean two-side pin layout:",
    "//---": "  N = pad_* (faces project_macro top edge / IO ring)",
    "//----": "  S = APB + clocks + irq (faces apb_splitter)",

    "VERILOG_FILES": [
        "dir::../../rtl/attoio_wrap.v",
        "dir::../../AttoIO/rtl/attoio_apb_if.v",
        "dir::../../AttoIO/rtl/attoio_memmux.v",
        "dir::../../AttoIO/rtl/attoio_gpio.v",
        "dir::../../AttoIO/rtl/attoio_ctrl.v",
        "dir::../../AttoIO/rtl/attoio_spi.v",
        "dir::../../AttoIO/rtl/attoio_timer.v",
        "dir::../../AttoIO/rtl/attoio_wdt.v",
        "dir::../../AttoIO/rtl/attoio_macro.v",
        "dir::../../AttoIO/models/dffram_rtl.v",
        "dir::../../frv32/rtl/attorv32.v"
    ],

    "VERILOG_DEFINES": [
        "NRV_SINGLE_PORT_REGF",
        "NRV_SHARED_ADDER",
        "NRV_SERIAL_SHIFT"
    ],

    "SYNTH_STRATEGY": "DELAY 0",

    "CLOCK_PORT":   ["sysclk", "clk_iop"],
    "CLOCK_PERIOD": 18.182,

    "PNR_SDC_FILE":     "dir::attoio_pnr.sdc",
    "SIGNOFF_SDC_FILE": "dir::attoio_signoff.sdc",

    "//-floorplan": "N and S each carry ~84/88 pins (slim wrapper). Aspect 2.0 makes the macro short and wide -- max N-face headroom for the pad bus, while still narrower than project_macro (~580 um vs 880 um).",
    "FP_SIZING":       "relative",
    "FP_CORE_UTIL":    70,
    "FP_ASPECT_RATIO": 2.0,
    "FP_CORE_MARGIN":  5,

    "FP_PIN_ORDER_CFG": "dir::pin_order.cfg",

    "PL_TARGET_DENSITY":              0.70,
    "PL_RESIZER_HOLD_SLACK_MARGIN":   0.10,
    "PL_RESIZER_SETUP_SLACK_MARGIN":  0.00,
    "RUN_POST_GRT_RESIZER_TIMING":    true,
    "GRT_RESIZER_HOLD_SLACK_MARGIN":  0.30,
    "GRT_RESIZER_SETUP_SLACK_MARGIN": 0.05,
    "GRT_RESIZER_ALLOW_SETUP_VIOS":   false,
    "DESIGN_REPAIR_MAX_WIRE_LENGTH":  400,
    "CTS_DISTANCE_BETWEEN_BUFFERS":   200,

    "GRT_ANTENNA_REPAIR_ITERS":       4,
    "DRT_ANTENNA_REPAIR_ITERS":       4,
    "DIODE_ON_PORTS":                 "in",
    "RUN_HEURISTIC_DIODE_INSERTION":  false,
    "GRT_ANTENNA_REPAIR_JUMPER_ONLY": true,
    "DRT_ANTENNA_REPAIR_JUMPER_ONLY": true,

    "DESIGN_IS_CORE": false,

    "PDK": "sky130A",
    "STD_CELL_LIBRARY": "sky130_fd_sc_hd"
}
